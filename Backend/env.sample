# ===== Azure SQL connection (.env) =====
SQLSERVER_HOST=myserver.database.windows.net
SQLSERVER_DATABASE=YourDatabaseName  # optional if you always pass --db
SQLSERVER_PORT=1433
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_TRUSTSERVERCERTIFICATE=no
SQLSERVER_TIMEOUT=30

# ---------- Choose ONE authentication method ----------
# 1) Microsoft Entra ID (Interactive) - pops a browser/device prompt
# SQLSERVER_AUTHENTICATION=ActiveDirectoryInteractive
# SQLSERVER_USER=your_upn@yourtenant.com

# 2) Entra Password (username + password)
# SQLSERVER_AUTHENTICATION=ActiveDirectoryPassword
# SQLSERVER_USER=your_upn@yourtenant.com
# SQLSERVER_PASSWORD=YourAADPassword123!

# 3) Entra Integrated (Windows domain-joined; ignores UID/PWD)
# SQLSERVER_AUTHENTICATION=ActiveDirectoryIntegrated

# 4) Managed Identity (when running in Azure; optional client id)
# SQLSERVER_AUTHENTICATION=ActiveDirectoryMsi
# SQLSERVER_USER= # leave empty
# SQLSERVER_PASSWORD= # leave empty
# AZURE_CLIENT_ID= # optional: user-assigned managed identity client ID

# 5) Service Principal (App Registration)
# SQLSERVER_AUTHENTICATION=ActiveDirectoryServicePrincipal
# SQLSERVER_USER=<app_client_id>
# SQLSERVER_PASSWORD=<app_client_secret>
# AZURE_TENANT_ID=<your_tenant_guid>

# 6) Access Token (advanced) - acquire token via azure-identity
# SQLSERVER_AUTHENTICATION=ActiveDirectoryAccessToken
# Option A: Use Service Principal for token
# AZURE_TENANT_ID=<tenant_guid>
# AZURE_CLIENT_ID=<app_client_id>
# AZURE_CLIENT_SECRET=<app_client_secret>
# Option B: Use Azure CLI login or Managed Identity (no extra env needed)
#   az login
